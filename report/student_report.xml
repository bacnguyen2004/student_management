<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_student_card" model="ir.actions.report">
        <field name="name">Student Card</field>
        <field name="model">student_management.student</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">student_management.report_student_card</field>
        <field name="report_file">student_management.report_student_card</field>
        <field name="binding_model_id" ref="model_student_management_student"/>
        <field name="binding_type">report</field>
    </record>

    <record id="action_report_course_students" model="ir.actions.report">
        <field name="name">Student List by Course</field>
        <field name="model">student_management.course</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">student_management.report_course_students</field>
        <field name="report_file">student_management.report_course_students</field>
        <field name="binding_model_id" ref="model_student_management_course"/>
        <field name="binding_type">report</field>
    </record>

    <record id="action_report_classroom_grades" model="ir.actions.report">
        <field name="name">Class Grade Report</field>
        <field name="model">student_management.classroom</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">student_management.report_classroom_grades</field>
        <field name="report_file">student_management.report_classroom_grades</field>
        <field name="binding_model_id" ref="model_student_management_classroom"/>
        <field name="binding_type">report</field>
    </record>

</odoo>