<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_student_management" model="ir.module.category">
        <field name="name">Student Management</field>
        <field name="sequence">50</field>
    </record>

    <record id="group_student_management_teacher" model="res.groups">
        <field name="name">Teacher</field>
        <field name="category_id" ref="module_category_student_management"/>
    </record>

    <record id="group_student_management_staff" model="res.groups">
        <field name="name">Staff</field>
        <field name="category_id" ref="module_category_student_management"/>
        <field name="implied_ids" eval="[(4, ref('group_student_management_teacher'))]"/>
    </record>

    <record id="group_student_management_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="module_category_student_management"/>
        <field name="implied_ids" eval="[(4, ref('group_student_management_staff'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin')), (4, ref('base.user_root'))]"/>
    </record>

    <!-- Teacher: only enrollments of courses they teach -->
    <record id="enrollment_teacher_rule" model="ir.rule">
        <field name="name">Teacher: own course enrollments</field>
        <field name="model_id" ref="model_student_management_enrollment"/>
        <field name="groups" eval="[(4, ref('group_student_management_teacher'))]"/>
        <field name="domain_force">[('course_id.teacher_id.user_id', '=', user.id)]</field>
    </record>

    <!-- Staff: all enrollments (OR with teacher rule when user has both groups) -->
    <record id="enrollment_staff_rule" model="ir.rule">
        <field name="name">Staff: all enrollments</field>
        <field name="model_id" ref="model_student_management_enrollment"/>
        <field name="groups" eval="[(4, ref('group_student_management_staff'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

</odoo>