<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_classroom_list" model="ir.ui.view">
        <field name="name">student_management.classroom.list</field>
        <field name="model">student_management.classroom</field>
        <field name="arch" type="xml">
            <list string="Classes">
                <field name="name"/>
                <field name="code"/>
                <field name="course_id"/>
                <field name="teacher_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="student_count"/>
                <field name="max_students"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_classroom_form" model="ir.ui.view">
        <field name="name">student_management.classroom.form</field>
        <field name="model">student_management.classroom</field>
        <field name="arch" type="xml">
            <form string="Class">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="course_id"/>
                            <field name="teacher_id"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="max_students"/>
                            <field name="student_count"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Students">
                            <field name="student_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_classroom_search" model="ir.ui.view">
        <field name="name">student_management.classroom.search</field>
        <field name="model">student_management.classroom</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="course_id"/>
                <field name="teacher_id"/>
                <filter name="active" string="Active" domain="[('active','=',True)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_course" string="Course" context="{'group_by': 'course_id'}"/>
                    <filter name="group_teacher" string="Teacher" context="{'group_by': 'teacher_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_classroom" model="ir.actions.act_window">
        <field name="name">Classes</field>
        <field name="res_model">student_management.classroom</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>