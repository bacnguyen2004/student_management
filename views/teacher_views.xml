<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_teacher_list" model="ir.ui.view">
        <field name="name">student_management.teacher.list</field>
        <field name="model">student_management.teacher</field>
        <field name="arch" type="xml">
            <list string="Teachers" decoration-muted="not active">
                <field name="name"/>
                <field name="email" widget="email"/>
                <field name="phone" widget="phone"/>
                <field name="specialization"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_teacher_kanban" model="ir.ui.view">
        <field name="name">student_management.teacher.kanban</field>
        <field name="model">student_management.teacher</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="specialization"/>
                <field name="user_id"/>
                <field name="active"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click p-2">
                            <div class="d-flex justify-content-between align-items-start gap-2">
                                <div>
                                    <strong class="d-block"><field name="name"/></strong>
                                    <span class="text-muted" t-if="record.specialization.raw_value">
                                        <field name="specialization"/>
                                    </span>
                                </div>
                                <span t-if="record.user_id.raw_value" class="badge rounded-pill text-bg-success">
                                    User linked
                                </span>
                            </div>
                            <div class="mt-2 text-muted" t-if="record.email.raw_value">
                                <i class="fa fa-envelope me-1" title="Email"/> <field name="email"/>
                            </div>
                            <div class="text-muted" t-if="record.phone.raw_value">
                                <i class="fa fa-phone me-1" title="Phone"/> <field name="phone"/>
                            </div>
                            <div t-if="!record.active.raw_value" class="text-danger mt-1">
                                Archived
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_teacher_form" model="ir.ui.view">
        <field name="name">student_management.teacher.form</field>
        <field name="model">student_management.teacher</field>
        <field name="arch" type="xml">
            <form string="Teacher">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Teacher name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="specialization"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="user_id"/>
                            <field name="email" widget="email"/>
                            <field name="phone" widget="phone"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Courses">
                            <field name="course_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_teacher_search" model="ir.ui.view">
        <field name="name">student_management.teacher.search</field>
        <field name="model">student_management.teacher</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="email"/>
                <field name="specialization"/>
                <filter name="active" string="Active" domain="[('active','=',True)]"/>
                <filter name="archived" string="Archived" domain="[('active','=',False)]"/>
                <filter name="linked_user" string="Linked User" domain="[('user_id','!=',False)]"/>
            </search>
        </field>
    </record>

    <record id="action_teacher" model="ir.actions.act_window">
        <field name="name">Teachers</field>
        <field name="res_model">student_management.teacher</field>
        <field name="view_mode">list,kanban,form</field>
    </record>
</odoo>
