<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_student_list" model="ir.ui.view">
        <field name="name">student_management.student.list</field>
        <field name="model">student_management.student</field>
        <field name="arch" type="xml">
            <list>
                <field name="student_code"/>
                <field name="name"/>
                <field name="gender"/>
                <field name="date_of_birth"/>
                <field name="age"/>
                <field name="course_count"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_student_kanban" model="ir.ui.view">
        <field name="name">student_management.student.kanban</field>
        <field name="model">student_management.student</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="student_code"/>
                <field name="email"/>
                <field name="gender"/>
                <field name="active"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <strong><field name="name"/></strong>
                            <div t-if="record.student_code.raw_value">
                                <field name="student_code"/>
                            </div>
                            <div t-if="record.email.raw_value">
                                <i class="fa fa-envelope" title="Email"/> <field name="email"/>
                            </div>
                            <div t-if="record.gender.raw_value">
                                <field name="gender"/>
                            </div>
                            <div t-if="!record.active.raw_value" class="text-danger">
                                Inactive
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_student_form" model="ir.ui.view">
        <field name="name">student_management.student.form</field>
        <field name="model">student_management.student</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_enrollments"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-graduation-cap">
                            <field name="course_count" widget="statinfo" string="Courses"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <field name="student_code" readonly="1" placeholder="Auto-generated on save"/>
                            <field name="name"/>
                            <field name="gender"/>
                            <field name="date_of_birth"/>
                            <field name="age"/>
                        </group>
                        <group>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Address">
                            <field name="address"/>
                        </page>
                        <page string="Note">
                            <field name="note"/>
                        </page>
                        <page string="Enrollments">
                            <field name="enrollment_ids"/>
                        </page>
                        <page string="Classes">
                            <field name="classroom_ids"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_student_search" model="ir.ui.view">
        <field name="name">student_management.student.search</field>
        <field name="model">student_management.student</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="student_code"/>
                <field name="email"/>
                <filter name="male" string="Male" domain="[('gender','=','male')]"/>
                <filter name="female" string="Female" domain="[('gender','=','female')]"/>
                <filter name="active" string="Active" domain="[('active','=',True)]"/>
                <filter name="inactive" string="Archived" domain="[('active','=',False)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_gender" string="Gender" context="{'group_by': 'gender'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">student_management.student</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

</odoo>