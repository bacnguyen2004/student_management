<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_student_list" model="ir.ui.view">
        <field name="name">student_management.student.list</field>
        <field name="model">student_management.student</field>
        <field name="arch" type="xml">
            <list decoration-muted="not active">
                <field name="student_code"/>
                <field name="name"/>
                <field name="gender"/>
                <field name="date_of_birth"/>
                <field name="age"/>
                <field name="course_count"/>
                <field name="email" widget="email"/>
                <field name="phone" widget="phone"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_student_kanban" model="ir.ui.view">
        <field name="name">student_management.student.kanban</field>
        <field name="model">student_management.student</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="student_code"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="gender"/>
                <field name="active"/>
                <field name="course_count"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click p-2">
                            <div class="d-flex justify-content-between align-items-start gap-2">
                                <div>
                                    <strong class="d-block"><field name="name"/></strong>
                                    <span t-if="record.student_code.raw_value" class="text-muted">
                                        <field name="student_code"/>
                                    </span>
                                </div>
                                <span class="badge rounded-pill text-bg-primary">
                                    <field name="course_count"/> courses
                                </span>
                            </div>
                            <div class="mt-2 text-muted" t-if="record.email.raw_value">
                                <i class="fa fa-envelope me-1" title="Email"/> <field name="email"/>
                            </div>
                            <div class="text-muted" t-if="record.phone.raw_value">
                                <i class="fa fa-phone me-1" title="Phone"/> <field name="phone"/>
                            </div>
                            <div class="mt-2" t-if="record.gender.raw_value">
                                <field name="gender"/>
                            </div>
                            <div t-if="!record.active.raw_value" class="text-danger mt-1">
                                Inactive
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_student_form" model="ir.ui.view">
        <field name="name">student_management.student.form</field>
        <field name="model">student_management.student</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_enrollments"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-graduation-cap">
                            <field name="course_count" widget="statinfo" string="Courses"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Student name"/>
                        </h1>
                        <h2 class="text-muted">
                            <field name="student_code" readonly="1" placeholder="Auto-generated on save"/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="gender"/>
                            <field name="date_of_birth"/>
                            <field name="age"/>
                        </group>
                        <group>
                            <field name="email" widget="email"/>
                            <field name="phone" widget="phone"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Address">
                            <field name="address"/>
                        </page>
                        <page string="Note">
                            <field name="note"/>
                        </page>
                        <page string="Enrollments">
                            <field name="enrollment_ids"/>
                        </page>
                        <page string="Classes">
                            <field name="classroom_ids"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_student_search" model="ir.ui.view">
        <field name="name">student_management.student.search</field>
        <field name="model">student_management.student</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="student_code"/>
                <field name="email"/>
                <filter name="male" string="Male" domain="[('gender','=','male')]"/>
                <filter name="female" string="Female" domain="[('gender','=','female')]"/>
                <filter name="active" string="Active" domain="[('active','=',True)]"/>
                <filter name="inactive" string="Archived" domain="[('active','=',False)]"/>
                <filter name="with_email" string="With Email" domain="[('email','!=',False)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_gender" string="Gender" context="{'group_by': 'gender'}"/>
                    <filter name="group_active" string="Archived" context="{'group_by': 'active'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">student_management.student</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

</odoo>
